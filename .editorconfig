# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cs,vb}]

# Define the 'private_fields' symbol group:
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

# Define the 'private_static_fields' symbol group
dotnet_naming_symbols.private_static_fields.applicable_kinds = field
dotnet_naming_symbols.private_static_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_static_fields.required_modifiers = static

# Define the 'underscored' naming style
dotnet_naming_style.underscored.capitalization = camel_case
dotnet_naming_style.underscored.required_prefix = _

# Define the 'private_fields_underscored' naming rule
dotnet_naming_rule.private_fields_underscored.symbols = private_fields
dotnet_naming_rule.private_fields_underscored.style = underscored
dotnet_naming_rule.private_fields_underscored.severity = warning

# Define the 'private_static_fields_none' naming rule
dotnet_naming_rule.private_static_fields_none.symbols = private_static_fields
dotnet_naming_rule.private_static_fields_none.style = underscored
dotnet_naming_rule.private_static_fields_none.severity = none

# Exception: Allow public properties named 'UUID'
dotnet_naming_symbols.public_UUID_property.applicable_kinds = property
dotnet_naming_symbols.public_UUID_property.applicable_accessibilities = public
dotnet_naming_symbols.public_UUID_property.required_names = UUID
dotnet_naming_rule.public_UUID_property_exception.symbols = public_UUID_property
dotnet_naming_rule.public_UUID_property_exception.style = none
dotnet_naming_rule.public_UUID_property_exception.severity = none

# Exception: Allow enums in all caps
# Define the 'enums_all_caps' symbol group
dotnet_naming_symbols.enums_all_caps.applicable_kinds = enum
# Define the 'all_caps' naming style
dotnet_naming_style.all_caps.capitalization = all_upper
# Define the 'enums_all_caps' naming rule
dotnet_naming_rule.enums_all_caps.symbols = enums_all_caps
dotnet_naming_rule.enums_all_caps.style = all_caps
dotnet_naming_rule.enums_all_caps.severity = none

